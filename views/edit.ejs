<%- include("partials/header") %>
<body>
  <h1>Edit Book</h1>
  <form action="/edit/<%= book.id %>" method="POST">
    <label>Title:</label>
    <input type="text" name="title" value="<%= book.title %>" required /><br>

    <label>Author:</label>
    <input type="text" name="author" value="<%= book.author %>" required /><br>

    <label>Rating:</label>
    <input type="number" name="rating" value="<%= book.rating %>" min="1" max="10" required /><br>

    <label>Date Read:</label>
    <input type="date" name="date_read" value="<%= book.date_read.toISOString().split('T')[0] %>" required /><br>

    <label>Notes:</label><br>
    <textarea name="notes"><%= book.notes %></textarea><br>

    <label>Cover ID:</label>
    <input type="text" name="cover_id" value="<%= book.cover_id %>" /><br>

    <button type="submit">Update Book</button>
  </form>
  <a href="/">← Back</a>
  <%- include("partials/footer") %>